version: '3.8'

services:
	# 1. CỔNG GÁC TRAEFIK
  traefik:
    image: traefik:v2.11
    command:
      - "--providers.docker=true"
      - "--providers.docker.swarmMode=true"
      - "--providers.docker.exposedbydefault=false"
      - "--entrypoints.web.address=:80"
      - "--entrypoints.websecure.address=:443"
      # Chuyển hướng tự động HTTP sang HTTPS
      - "--entrypoints.web.http.redirections.entryPoint.to=websecure"
      - "--entrypoints.web.http.redirections.entryPoint.scheme=https"
      # Cấu hình xin chứng chỉ Let's Encrypt
      - "--certificatesresolvers.myresolver.acme.httpchallenge=true"
      - "--certificatesresolvers.myresolver.acme.httpchallenge.entrypoint=web"
      - "--certificatesresolvers.myresolver.acme.email=nbao1502@gmail.com" # <--- 1. ĐỔI THÀNH EMAIL THẬT CỦA BẠN
      - "--certificatesresolvers.myresolver.acme.storage=/letsencrypt/acme.json"
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock:ro"
      - "traefik-certs:/letsencrypt"
    deploy:
      placement:
        constraints:
          - node.role == manager # Traefik BẮT BUỘC phải nằm ở Manager
  app:
    image: nbao1502/final:v1
#    ports:
#      - "80:3000"
    deploy:
      replicas: 3
      update_config:
        parallelism: 1
        delay: 10s
      restart_policy:
        condition: on-failure
      labels:
        - "traefik.enable=true"
        # Chú ý dấu backtick ` bao quanh tên miền
        - "traefik.http.routers.myapp.rule=Host(`namcloud.xyz`)"
        - "traefik.http.routers.myapp.entrypoints=websecure"
        - "traefik.http.routers.myapp.tls.certresolver=myresolver"
        # Báo cho Traefik biết app của bạn chạy ở cổng 3000 bên trong container
        - "traefik.http.services.myapp.loadbalancer.server.port=3000"
  visualizer:
    image: dockersamples/visualizer:stable
    volumes:
      - "/var/run/docker.sock:/var/run/docker.sock"
    deploy:
      placement:
        constraints: [node.role == manager]
      labels:
        - "traefik.enable=true"
        # Đặt một tên miền phụ cho Visualizer (nhớ trỏ record DNS của tên miền phụ này về IP nhé)
        - "traefik.http.routers.visualizer.rule=Host(`vis.namcloud.xyz`)" 
        - "traefik.http.routers.visualizer.entrypoints=websecure"
        - "traefik.http.routers.visualizer.tls.certresolver=myresolver"
        - "traefik.http.services.visualizer.loadbalancer.server.port=8080"

networks:
  default:
    driver: overlay
